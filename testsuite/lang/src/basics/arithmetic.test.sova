package langsuite/basics on test

test "addition" {
    assert 1 + 2 == 3
    assert 10 + 20 == 30
}

test "subtraction" {
    assert 5 - 3 == 2
    assert 100 - 1 == 99
}

test "multiplication" {
    assert 3 * 4 == 12
    assert 7 * 8 == 56
}

test "division" {
    assert 20 / 4 == 5
    assert 100 / 25 == 4
}

test "modulo" {
    assert 10 % 3 == 1
    assert 17 % 5 == 2
}

test "precedence" {
    assert 1 + 2 * 3 == 7
    assert (1 + 2) * 3 == 9
}

test "negation" {
    let x = 5
    assert -x == -5
}

test "float arithmetic" {
    assert 1.5 + 2.5 == 4.0
    assert 10.0 / 4.0 == 2.5
}
