package langsuite/basics on test

test "int literal" {
    let x: int = 42
    assert x == 42
}

test "float literal" {
    let x: float = 3.5
    assert x == 3.5
}

test "string literal" {
    let s: string = "hello"
    assert s == "hello"
}

test "bool literals" {
    assert true == true
    assert false == false
    assert true != false
}

test "char literal" {
    let c: char = 'A'
    assert c == 'A'
}

test "char inequality" {
    let a: char = 'a'
    let b: char = 'b'
    assert a != b
}

test "none literal in option" {
    let x: option<int> = none
    assert x == none
}
