package langsuite/oop on test

mixin Labeled {
    label: string = ""

    func setLabel(t: string) {
        this.label = t
    }

    func getLabel(): string {
        return this.label
    }
}

type Item with Labeled {
    name: string = ""
}

test "mixin field accessible" {
    let it = new Item()
    it.name = "widget"
    it.label = "alpha"
    assert it.name == "widget"
    assert it.label == "alpha"
}

test "mixin method dispatch" {
    let it = new Item()
    it.setLabel("beta")
    assert it.getLabel() == "beta"
}

mixin Counted {
    count: int = 0

    func bump() {
        this.count = this.count + 1
    }
}

type Page with Counted {
    url: string = ""

    func tag(s: string): string {
        return "tag:" + s
    }
}

test "method named tag (was soft-reserved)" {
    let p = new Page()
    assert p.tag("hello") == "tag:hello"
}

type Bookmark {
    tag: string = ""
    title: string = ""
}

test "field named tag (was soft-reserved)" {
    let b = new Bookmark()
    b.tag = "fav"
    b.title = "Home"
    assert b.tag == "fav"
    assert b.title == "Home"
}

test "single mixin Counted on Page" {
    let p = new Page()
    p.url = "/home"
    p.bump()
    p.bump()
    p.bump()
    assert p.url == "/home"
    assert p.count == 3
}
