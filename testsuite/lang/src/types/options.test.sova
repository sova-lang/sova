package langsuite/types on test

test "option is none" {
    let x: option<int> = none
    assert x == none
}

test "option holds int literal" {
    let x: option<int> = 42
    assert x != none
    assert (x ?? 0) == 42
}

test "option holds float literal" {
    let x: option<float> = 3.5
    assert x != none
    assert (x ?? 0.0) == 3.5
}

test "option of string holds value" {
    let s: option<string> = "hello"
    assert s != none
}

test "option coalesce on none" {
    let x: option<int> = none
    let y = x ?? 99
    assert y == 99
}

func mayDouble(x: int, doIt: bool): option<int> {
    if doIt {
        return x * 2
    }
    return none
}

test "option from function returning none" {
    let r = mayDouble(5, false)
    assert r == none
}

test "option from function holding value" {
    let r = mayDouble(5, true)
    assert (r ?? -1) == 10
}
