        frontend: "(s) => { const ms = Date.parse(s); if (Number.isNaN(ms)) return -1; return ms * 1000000; }",
        backend: "func(s string) int64 { t, err := time.Parse(time.RFC3339Nano, s); if err != nil { return -1 }; return t.UnixNano() }"
    }

    /// __localZoneName returns the host's local IANA timezone
    /// name. Backend: `time.Local.String()` (resolves `$TZ` /
    /// `/etc/localtime`). Frontend:
    /// `Intl.DateTimeFormat().resolvedOptions().timeZone`.
    func __localZoneName(): string = {
        frontend: "() => { try { return Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC'; } catch (e) { return 'UTC'; } }",
        backend: "func() string { n := time.Local.String(); if n == \"\" || n == \"Local\" { return \"UTC\" }; return n }"
    }

    /// __zoneIsValid reports whether `name` is a recognised IANA
