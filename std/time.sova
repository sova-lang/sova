        backend: "func(ns int64, z string) int64 { loc, err := time.LoadLocation(z); if err != nil { loc = time.UTC }; return int64(time.Unix(0, ns).In(loc).Weekday()) }"
    }

    /// __dateTimeToISO formats `nanos` in the named zone as
    /// `2026-06-16T14:34:56+02:00` (offset suffix) or
    /// `...Z` when the zone resolves to UTC. Frontend builds
    /// the string from the broken-down parts plus the zone's
    /// offset at this moment.
    func __dateTimeToISO(nanos: int, zoneName: string): string = {
        frontend: "(ns, z) => { const ms = Number(ns) / 1e6; const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: z, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of fmt.formatToParts(new Date(ms))) o[p.type] = p.value; const h = parseInt(o.hour, 10); const hh = String(h === 24 ? 0 : h).padStart(2, '0'); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), h === 24 ? 0 : h, parseInt(o.minute, 10), parseInt(o.second, 10)); let offSec = Math.floor((asUtc - ms) / 1000); let sign = '+'; if (offSec < 0) { sign = '-'; offSec = -offSec; } const oh = String(Math.floor(offSec / 3600)).padStart(2, '0'); const om = String(Math.floor((offSec % 3600) / 60)).padStart(2, '0'); const suffix = offSec === 0 ? 'Z' : (sign + oh + ':' + om); return o.year + '-' + o.month + '-' + o.day + 'T' + hh + ':' + o.minute + ':' + o.second + suffix; }",
        backend: "func(ns int64, z string) string { loc, err := time.LoadLocation(z); if err != nil { loc = time.UTC }; return time.Unix(0, ns).In(loc).Format(time.RFC3339Nano) }"
    }

    /// __dateTimeParseNanos parses an RFC 3339 / ISO 8601 string
    /// to UTC nanoseconds. Same `time.Parse` / `Date.parse`
    /// shape as `__instantParse` — split into two externs only
    /// so `parseDateTime` can recover the zone metadata in one
    /// pass without packed-string tricks.
    func __dateTimeParseNanos(iso: string): int = {
        frontend: "(s) => { const ms = Date.parse(s); if (Number.isNaN(ms)) return 0; return ms * 1000000; }",
        backend: "func(s string) int64 { t, err := time.Parse(time.RFC3339Nano, s); if err != nil { return 0 }; return t.UnixNano() }"
    }

    /// __dateTimeParseZone parses the zone portion out of an ISO
    /// string and returns the canonical zone name —
    /// `\"UTC\"` for a trailing `Z`, `\"+HH:MM\"` /
    /// `\"-HH:MM\"` for a numeric offset. Returns `\"\"` on
    /// parse failure (the wrapper turns that into `none`).
    func __dateTimeParseZone(iso: string): string = {
        frontend: "(s) => { if (!s) return ''; if (Number.isNaN(Date.parse(s))) return ''; if (/Z$/.test(s)) return 'UTC'; const m = /([+-]\\d{2}:?\\d{2})$/.exec(s); if (!m) return 'UTC'; const o = m[1]; return o.length === 5 ? o.slice(0,3) + ':' + o.slice(3) : o; }",
        backend: "func(s string) string { t, err := time.Parse(time.RFC3339Nano, s); if err != nil { return \"\" }; n := t.Location().String(); if n == \"\" || n == \"Local\" || n == \"UTC\" { if t.Format(\"-07:00\") == \"+00:00\" { return \"UTC\" }; return t.Format(\"-07:00\") }; return n }"
    }

    /// __dateTimeFromParts constructs a UTC-nanosecond stamp from
    /// broken-down wall-clock parts in the named zone. Frontend
    /// computes via the "format-then-diff" trick: build the
    /// UTC ms of the wall-clock parts, then ask the host how
    /// many seconds the zone is offset from UTC at that moment,
    /// and subtract. Out-of-range parts normalise (month=13
    /// rolls into next year) on both sides.
    func __dateTimeFromParts(year: int, month: int, day: int, hour: int, minute: int, second: int, nano: int, zoneName: string): int = {
        frontend: "(y, mo, d, h, mi, s, ns, z) => { const wallMs = Date.UTC(Number(y), Number(mo) - 1, Number(d), Number(h), Number(mi), Number(s)); const offOf = (zz, mms) => { const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: zz, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of fmt.formatToParts(new Date(mms))) o[p.type] = p.value; const hh = parseInt(o.hour, 10) === 24 ? 0 : parseInt(o.hour, 10); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), hh, parseInt(o.minute, 10), parseInt(o.second, 10)); return Math.floor((asUtc - mms) / 1000); }; let off = offOf(z, wallMs); for (let i = 0; i < 2; i++) { off = offOf(z, wallMs - off * 1000); } const utcMs = wallMs - off * 1000; return BigInt(utcMs) * 1000000n + BigInt(Number(ns)); }",
        backend: "func(y, mo, d, h, mi, s, ns int64, z string) int64 { loc, err := time.LoadLocation(z); if err != nil { loc = time.UTC }; return time.Date(int(y), time.Month(mo), int(d), int(h), int(mi), int(s), int(ns), loc).UnixNano() }"
    }

    /// __dateToISO formats `y/m/d` as `yyyy-MM-dd` with
    /// zero-padded fields.
    func __dateToISO(year: int, month: int, day: int): string = {
        frontend: "(y, m, d) => { const pad = (v, n) => String(v).padStart(n, '0'); return pad(y, 4) + '-' + pad(m, 2) + '-' + pad(d, 2); }",
        backend: "func(y, m, d int64) string { return fmt.Sprintf(\"%04d-%02d-%02d\", y, m, d) }"
    }

    /// __dateWeekday returns the weekday (0=Sun..6=Sat) for
    /// the given calendar date, computed in UTC. Same answer on
    /// both sides.
    func __dateWeekday(year: int, month: int, day: int): int = {
        frontend: "(y, m, d) => new Date(Date.UTC(Number(y), Number(m) - 1, Number(d))).getUTCDay()",
        backend: "func(y, m, d int64) int64 { return int64(time.Date(int(y), time.Month(m), int(d), 0, 0, 0, 0, time.UTC).Weekday()) }"
    }

    /// __dateAdd advances a calendar date by `days+months+years`
    /// (any combination, including negative). Returns the
    /// resulting date packed as `year*10000 + month*100 + day`
    /// so Sova can unpack into a new `Date` struct without
    /// needing a struct-return extern. Month-end clamping is
    /// host-default: `Jan 31 + 1 month` → `Mar 3` (Go's
    /// `AddDate`) or `Feb 28/29` (JS `Date` constructor with
    /// clamp). Go's behaviour wins because that's where most
    /// arithmetic lives; the frontend matches by manual clamp.
    func __dateAdd(year: int, month: int, day: int, days: int, months: int, years: int): int = {
        frontend: "(y, mo, d, dd, dm, dy) => { const nm = Number(mo) - 1 + Number(dm); const ny = Number(y) + Number(dy) + Math.floor(nm / 12); const m2 = ((nm % 12) + 12) % 12; const daysIn = [31, ((ny%4===0&&ny%100!==0)||ny%400===0)?29:28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]; const dClamp = Math.min(Number(d), daysIn[m2]); const ms = Date.UTC(ny, m2, dClamp) + Number(dd) * 86400000; const out = new Date(ms); return out.getUTCFullYear() * 10000 + (out.getUTCMonth() + 1) * 100 + out.getUTCDate(); }",
        backend: "func(y, m, d, dd, dm, dy int64) int64 { t := time.Date(int(y), time.Month(m), int(d), 0, 0, 0, 0, time.UTC).AddDate(int(dy), int(dm), int(dd)); return int64(t.Year()) * 10000 + int64(t.Month()) * 100 + int64(t.Day()) }"
    }

    /// __dateDaysBetween returns the count of calendar days from
    /// `(y1, m1, d1)` to `(y2, m2, d2)`. Positive when the
    /// second date is later. Uses midnight-UTC anchoring so the
    /// answer is timezone-independent (a "calendar day" in this
    /// API is the UTC-anchored day, NOT a local-zone day —
    /// the difference can matter for users in non-UTC zones at
    /// hours close to midnight).
    func __dateDaysBetween(y1: int, m1: int, d1: int, y2: int, m2: int, d2: int): int = {
        frontend: "(y1, m1, d1, y2, m2, d2) => { const a = Date.UTC(Number(y1), Number(m1) - 1, Number(d1)); const b = Date.UTC(Number(y2), Number(m2) - 1, Number(d2)); return Math.round((b - a) / 86400000); }",
        backend: "func(y1, m1, d1, y2, m2, d2 int64) int64 { a := time.Date(int(y1), time.Month(m1), int(d1), 0, 0, 0, 0, time.UTC); b := time.Date(int(y2), time.Month(m2), int(d2), 0, 0, 0, 0, time.UTC); return int64(b.Sub(a).Hours() / 24) }"
    }

    /// __dateAtStartOfDay returns the UTC-nanosecond stamp of
    /// `00:00:00` on the given calendar date in the named zone.
    /// E.g. `(2026, 6, 16, "Europe/Berlin")` → the nanos for
    /// `2026-06-16T00:00:00+02:00` (CEST). The result is an
    /// `Instant` (zone-independent); the zone parameter only
    /// affects WHICH wall-clock midnight you're asking for.
    func __dateAtStartOfDay(year: int, month: int, day: int, zoneName: string): int = {
        frontend: "(y, m, d, z) => { const wallMs = Date.UTC(Number(y), Number(m) - 1, Number(d), 0, 0, 0); const offOf = (zz, mms) => { const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: zz, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of fmt.formatToParts(new Date(mms))) o[p.type] = p.value; const hh = parseInt(o.hour, 10) === 24 ? 0 : parseInt(o.hour, 10); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), hh, parseInt(o.minute, 10), parseInt(o.second, 10)); return Math.floor((asUtc - mms) / 1000); }; let off = offOf(z, wallMs); for (let i = 0; i < 2; i++) { off = offOf(z, wallMs - off * 1000); } return BigInt(wallMs - off * 1000) * 1000000n; }",
        backend: "func(y, m, d int64, z string) int64 { loc, err := time.LoadLocation(z); if err != nil { loc = time.UTC }; return time.Date(int(y), time.Month(m), int(d), 0, 0, 0, 0, loc).UnixNano() }"
    }

    /// __dateParse parses a `yyyy-MM-dd` string into a packed
    /// `year*10000 + month*100 + day` int, or -1 on malformed
    /// input. Strict — only accepts the canonical ISO form,
    /// no extra whitespace or trailing characters.
    func __dateParse(iso: string): int = {
        frontend: "(s) => { const m = /^(\\d{4})-(\\d{2})-(\\d{2})$/.exec(s); if (!m) return -1; return Number(m[1]) * 10000 + Number(m[2]) * 100 + Number(m[3]); }",
        backend: "func(s string) int64 { t, err := time.Parse(\"2006-01-02\", s); if err != nil { return -1 }; return int64(t.Year()) * 10000 + int64(t.Month()) * 100 + int64(t.Day()) }"
    }

    /// __formatTimePattern does a regex-based token-replace over
    /// `pattern`, substituting `yyyy`/`MM`/`dd`/`HH`/`mm`/`ss`/
    /// etc. with the corresponding broken-down field values.
    /// Anything that isn't a recognised token passes through
    /// verbatim — `.`, `-`, `:`, space, even letters that don't
    /// form a token (so `T` in an ISO-like pattern works).
    /// Both sides use the same regex (RE2-compatible) and
    /// alternation order (longest variants first); output is
    /// identical character-for-character.
    func __formatTimePattern(year: int, month: int, day: int, hour: int, minute: int, second: int, nano: int, pattern: string): string = {
        frontend: "(y, mo, d, h, mi, s, ns, pat) => { const pad = (v, n) => String(v).padStart(n, '0'); const yn = Number(y), mon = Number(mo), dn = Number(d), hn = Number(h), min = Number(mi), sn = Number(s), nsn = Number(ns); return String(pat).replace(/yyyy|yy|MM|M|dd|d|HH|H|mm|m|ss|s|SSS/g, t => { switch (t) { case 'yyyy': return pad(yn, 4); case 'yy': return pad(yn % 100, 2); case 'MM': return pad(mon, 2); case 'M': return String(mon); case 'dd': return pad(dn, 2); case 'd': return String(dn); case 'HH': return pad(hn, 2); case 'H': return String(hn); case 'mm': return pad(min, 2); case 'm': return String(min); case 'ss': return pad(sn, 2); case 's': return String(sn); case 'SSS': return pad(Math.floor(nsn / 1000000), 3); } return t; }); }",
        backend("regexp"): "func(y, mo, d, h, mi, s, ns int64, pat string) string { re := regexp.MustCompile(\"yyyy|yy|MM|M|dd|d|HH|H|mm|m|ss|s|SSS\"); return re.ReplaceAllStringFunc(pat, func(t string) string { switch t { case \"yyyy\": return fmt.Sprintf(\"%04d\", y); case \"yy\": return fmt.Sprintf(\"%02d\", y%100); case \"MM\": return fmt.Sprintf(\"%02d\", mo); case \"M\": return fmt.Sprintf(\"%d\", mo); case \"dd\": return fmt.Sprintf(\"%02d\", d); case \"d\": return fmt.Sprintf(\"%d\", d); case \"HH\": return fmt.Sprintf(\"%02d\", h); case \"H\": return fmt.Sprintf(\"%d\", h); case \"mm\": return fmt.Sprintf(\"%02d\", mi); case \"m\": return fmt.Sprintf(\"%d\", mi); case \"ss\": return fmt.Sprintf(\"%02d\", s); case \"s\": return fmt.Sprintf(\"%d\", s); case \"SSS\": return fmt.Sprintf(\"%03d\", ns/1000000) }; return t }) }"
    }

    /// __parseTimePattern is the inverse of `__formatTimePattern`.
    /// Converts `pattern` into a regex (anchored `^...$` with
    /// `\\d{N}` capture groups in place of tokens, all other
    /// pattern characters quoted as literals), matches `input`,
    /// then maps captures back to year/month/day/hour/min/sec/ns
    /// and constructs a UTC-nanosecond stamp at the given zone.
    /// Returns Int64.MinValue (-9223372036854775807) on any
    /// mismatch — the Sova wrappers turn that into `none`.
    func __parseTimePattern(input: string, pattern: string, zoneName: string): int = {
        frontend: "(input, pat, zoneName) => { const tokRe = /yyyy|yy|MM|M|dd|d|HH|H|mm|m|ss|s|SSS/g; const tokens = []; let reSrc = '^'; let last = 0; let m; while ((m = tokRe.exec(String(pat))) !== null) { const lit = String(pat).slice(last, m.index); reSrc += lit.replace(/[.*+?^${}()|\\[\\]\\\\]/g, '\\\\$&'); const tk = m[0]; tokens.push(tk); switch (tk) { case 'yyyy': reSrc += '(\\\\d{4})'; break; case 'yy': reSrc += '(\\\\d{2})'; break; case 'MM': reSrc += '(\\\\d{2})'; break; case 'M': reSrc += '(\\\\d{1,2})'; break; case 'dd': reSrc += '(\\\\d{2})'; break; case 'd': reSrc += '(\\\\d{1,2})'; break; case 'HH': reSrc += '(\\\\d{2})'; break; case 'H': reSrc += '(\\\\d{1,2})'; break; case 'mm': reSrc += '(\\\\d{2})'; break; case 'm': reSrc += '(\\\\d{1,2})'; break; case 'ss': reSrc += '(\\\\d{2})'; break; case 's': reSrc += '(\\\\d{1,2})'; break; case 'SSS': reSrc += '(\\\\d{3})'; break; } last = m.index + tk.length; } reSrc += String(pat).slice(last).replace(/[.*+?^${}()|\\[\\]\\\\]/g, '\\\\$&'); reSrc += '$'; let re; try { re = new RegExp(reSrc); } catch (e) { return -9223372036854775807n; } const mm = re.exec(String(input)); if (!mm) return -9223372036854775807n; let y = 1970, mo = 1, d = 1, h = 0, mi = 0, s = 0, ns = 0; for (let i = 0; i < tokens.length; i++) { const v = parseInt(mm[i + 1], 10); switch (tokens[i]) { case 'yyyy': y = v; break; case 'yy': y = 2000 + v; break; case 'MM': case 'M': mo = v; break; case 'dd': case 'd': d = v; break; case 'HH': case 'H': h = v; break; case 'mm': case 'm': mi = v; break; case 'ss': case 's': s = v; break; case 'SSS': ns = v * 1000000; break; } } const wallMs = Date.UTC(y, mo - 1, d, h, mi, s); const offOf = (zz, mms) => { const ifmt = new Intl.DateTimeFormat('en-CA', {timeZone: zz, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of ifmt.formatToParts(new Date(mms))) o[p.type] = p.value; const hh = parseInt(o.hour, 10) === 24 ? 0 : parseInt(o.hour, 10); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), hh, parseInt(o.minute, 10), parseInt(o.second, 10)); return Math.floor((asUtc - mms) / 1000); }; let off = offOf(zoneName, wallMs); for (let i = 0; i < 2; i++) { off = offOf(zoneName, wallMs - off * 1000); } return BigInt(wallMs - off * 1000) * 1000000n + BigInt(ns); }",
        backend("regexp"): "func(input, pat, zoneName string) int64 { tokRe := regexp.MustCompile(\"yyyy|yy|MM|M|dd|d|HH|H|mm|m|ss|s|SSS\"); idxs := tokRe.FindAllStringIndex(pat, -1); var reSrc string = \"^\"; last := 0; tokens := []string{}; for _, m := range idxs { reSrc += regexp.QuoteMeta(pat[last:m[0]]); tk := pat[m[0]:m[1]]; tokens = append(tokens, tk); switch tk { case \"yyyy\": reSrc += \"(\\\\d{4})\"; case \"yy\": reSrc += \"(\\\\d{2})\"; case \"MM\": reSrc += \"(\\\\d{2})\"; case \"M\": reSrc += \"(\\\\d{1,2})\"; case \"dd\": reSrc += \"(\\\\d{2})\"; case \"d\": reSrc += \"(\\\\d{1,2})\"; case \"HH\": reSrc += \"(\\\\d{2})\"; case \"H\": reSrc += \"(\\\\d{1,2})\"; case \"mm\": reSrc += \"(\\\\d{2})\"; case \"m\": reSrc += \"(\\\\d{1,2})\"; case \"ss\": reSrc += \"(\\\\d{2})\"; case \"s\": reSrc += \"(\\\\d{1,2})\"; case \"SSS\": reSrc += \"(\\\\d{3})\" }; last = m[1] }; reSrc += regexp.QuoteMeta(pat[last:]) + \"$\"; re, err := regexp.Compile(reSrc); if err != nil { return -9223372036854775807 }; mm := re.FindStringSubmatch(input); if mm == nil { return -9223372036854775807 }; var y, mo, d, h, mi, s, ns int64 = 1970, 1, 1, 0, 0, 0, 0; for i, tk := range tokens { var v int64; for _, c := range mm[i+1] { v = v*10 + int64(c-'0') }; switch tk { case \"yyyy\": y = v; case \"yy\": y = 2000 + v; case \"MM\", \"M\": mo = v; case \"dd\", \"d\": d = v; case \"HH\", \"H\": h = v; case \"mm\", \"m\": mi = v; case \"ss\", \"s\": s = v; case \"SSS\": ns = v * 1000000 } }; loc, lerr := time.LoadLocation(zoneName); if lerr != nil { loc = time.UTC }; return time.Date(int(y), time.Month(mo), int(d), int(h), int(mi), int(s), int(ns), loc).UnixNano() }"
    }
}

