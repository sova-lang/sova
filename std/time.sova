        backend: "func(n string) bool { if n == \"\" { return false }; if len(n) == 6 && (n[0] == '+' || n[0] == '-') && n[3] == ':' { return true }; _, err := time.LoadLocation(n); return err == nil }"
    }

    /// __zoneOffsetAt returns the UTC offset (in whole seconds)
    /// the named zone has at the given Instant. Positive east
    /// of UTC.
    func __zoneOffsetAt(zoneName: string, nanos: int): int = {
        frontend: "(z, ns) => { try { const ms = Number(ns) / 1e6; const m = /^([+-])(\\d{2}):(\\d{2})$/.exec(z); if (m) { return (m[1] === '-' ? -1 : 1) * (parseInt(m[2], 10) * 3600 + parseInt(m[3], 10) * 60); } const d = new Date(ms); const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: z, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const parts = fmt.formatToParts(d); const o = {}; for (const p of parts) o[p.type] = p.value; const asUtc = Date.UTC(+o.year, +o.month - 1, +o.day === 24 ? 0 : +o.day, +o.hour === 24 ? 0 : +o.hour, +o.minute, +o.second); return Math.floor((asUtc - ms) / 1000); } catch (e) { return 0; } }",
        backend: "func(z string, ns int64) int64 { loc, err := time.LoadLocation(z); if err != nil { if len(z) == 6 && (z[0] == '+' || z[0] == '-') { var hh, mm int; fmt.Sscanf(z, \"%3d:%2d\", &hh, &mm); sign := int64(1); if z[0] == '-' { sign = -1; hh = -hh }; return sign * (int64(hh) * 3600 + int64(mm) * 60) }; return 0 }; _, off := time.Unix(0, ns).In(loc).Zone(); return int64(off) }"
