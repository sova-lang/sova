    /// __zoneIsDSTAt reports whether the named zone is observing
    /// DST at the given Instant. Backend uses Go's built-in
    /// `time.Time.IsDST()` (Go 1.17+); frontend compares the
    /// zone's offset at this moment to its offsets at January-15
    /// and July-15 of the same year — the standard
    /// hemisphere-agnostic heuristic. Helper `offOf` is inlined
    /// to keep this extern self-contained.
    func __zoneIsDSTAt(zoneName: string, nanos: int): bool = {
        frontend: "(z, ns) => { try { if (!z || z === 'UTC' || /^[+-]\\d{2}:\\d{2}$/.test(z)) return false; const offOf = (zz, nn) => { const mms = Number(nn) / 1e6; const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: zz, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of fmt.formatToParts(new Date(mms))) o[p.type] = p.value; const h = parseInt(o.hour, 10) === 24 ? 0 : parseInt(o.hour, 10); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), h, parseInt(o.minute, 10), parseInt(o.second, 10)); return Math.floor((asUtc - mms) / 1000); }; const cur = offOf(z, ns); const year = new Date(Number(ns) / 1e6).getUTCFullYear(); const janMs = Date.UTC(year, 0, 15); const julMs = Date.UTC(year, 6, 15); const oJan = offOf(z, BigInt(janMs) * 1000000n); const oJul = offOf(z, BigInt(julMs) * 1000000n); if (oJan === oJul) return false; return cur === Math.max(oJan, oJul); } catch (e) { return false; } }",
        backend: "func(z string, ns int64) bool { loc, err := time.LoadLocation(z); if err != nil { return false }; return time.Unix(0, ns).In(loc).IsDST() }"
    }

    /// __zoneObservesDST reports whether the named zone has any
    /// DST rules in `year` — i.e. whether its January offset
    /// differs from its July offset.
    func __zoneObservesDST(zoneName: string, year: int): bool = {
        frontend: "(z, y) => { try { if (!z || z === 'UTC' || /^[+-]\\d{2}:\\d{2}$/.test(z)) return false; const offOf = (zz, mms) => { const fmt = new Intl.DateTimeFormat('en-CA', {timeZone: zz, year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12: false}); const o = {}; for (const p of fmt.formatToParts(new Date(mms))) o[p.type] = p.value; const h = parseInt(o.hour, 10) === 24 ? 0 : parseInt(o.hour, 10); const asUtc = Date.UTC(parseInt(o.year, 10), parseInt(o.month, 10) - 1, parseInt(o.day, 10), h, parseInt(o.minute, 10), parseInt(o.second, 10)); return Math.floor((asUtc - mms) / 1000); }; const janMs = Date.UTC(Number(y), 0, 15); const julMs = Date.UTC(Number(y), 6, 15); return offOf(z, janMs) !== offOf(z, julMs); } catch (e) { return false; } }",
        backend: "func(z string, y int64) bool { loc, err := time.LoadLocation(z); if err != nil { return false }; jan := time.Date(int(y), time.January, 15, 12, 0, 0, 0, loc); jul := time.Date(int(y), time.July, 15, 12, 0, 0, 0, loc); _, oJan := jan.Zone(); _, oJul := jul.Zone(); return oJan != oJul }"
